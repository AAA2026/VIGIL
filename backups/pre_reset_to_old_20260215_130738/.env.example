# Development environment template
# Copy this to .env.development and update as needed

# Database (development)
# Use a dedicated dev DB name to avoid clashing with prod.
DATABASE_URL=postgresql+psycopg://vigil:vigil@localhost:5432/vigil_dev
DB_ECHO=1

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Frontend
VITE_API_URL=http://localhost:5000

# Logging
LOG_LEVEL=DEBUG
