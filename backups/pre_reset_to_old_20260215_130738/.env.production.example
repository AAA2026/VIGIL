# Vigil Production Database Configuration
# Copy to .env.production and adjust for your environment

# ===== DATABASE CONFIGURATION =====
# Production: Use Azure Database for PostgreSQL or AWS RDS
# Example PostgreSQL connection string (production DB name)
DATABASE_URL=postgresql+psycopg://vigil:YOUR_STRONG_PASSWORD@postgres.database.azure.com:5432/vigil_prod?sslmode=require

# Connection Pool Settings (PostgreSQL only)
# Number of persistent connections to maintain
DB_POOL_SIZE=20
# Additional overflow connections allowed when pool exhausted
DB_MAX_OVERFLOW=10
# Recycle connections after N seconds (prevent stale connections)
DB_POOL_RECYCLE=3600
# Test connection before use (recommended)
DB_POOL_PRE_PING=1

# ===== DATA RETENTION =====
# How long to keep resolved incidents (days)
INCIDENT_RETENTION_DAYS=30

# Path to archive old incidents (cold storage)
INCIDENT_ARCHIVE_PATH=/data/archives

# Enable automatic archival on a schedule (requires ENABLE_AUTO_ARCHIVAL=1)
# Runs every 24 hours by default
ENABLE_AUTO_ARCHIVAL=1

# ===== LOGGING & DEBUGGING =====
# Disable SQL debug logs in production (huge performance impact)
DB_ECHO=0

# JWT secret for API auth (required)
JWT_SECRET=change_me_to_a_strong_secret
JWT_ALG=HS256

# ===== FLASK SETTINGS =====
FLASK_ENV=production
# Secret key for sessions (use strong random string)
SECRET_KEY=your_secret_key_here_min_32_chars_recommended

# ===== FRONTEND =====
VITE_API_URL=https://vigil-api.yourdomain.com

# ===== SECURITY =====
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://vigil.yourdomain.com,https://admin.yourdomain.com

# ===== MONITORING & OBSERVABILITY =====
# Optional: Send logs to external service
DATADOG_API_KEY=your_key
SENTRY_DSN=https://your_sentry_dsn

# ===== DEPLOYMENT SPECIFIC =====
# For Azure deployments
AZURE_RESOURCE_GROUP=vigil-rg
AZURE_LOCATION=eastus

# For AWS deployments
AWS_REGION=us-east-1
AWS_RDS_ENDPOINT=vigil-db.chqzw62s.us-east-1.rds.amazonaws.com

# ===== BACKUP & DISASTER RECOVERY =====
# Enable PostgreSQL replication replica (read-only copy for reporting)
# Set to standby server IP/hostname if using replication
PG_REPLICATION_REPLICA=
